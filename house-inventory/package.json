{
  "name": "house-inventory",
  "version": "0.3.0",
  "description": "House asset inventory — Home Assistant add-on",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun run scripts/build.ts",
    "build:backend": "bun build ./src/index.ts --target=bun --outdir=./dist --minify",
    "start": "bun dist/index.js",
    "test": "bun test src/__tests__/",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.frontend.json",
    "lint": "oxlint src/frontend/",
    "fmt": "oxfmt --write src/",
    "fmt:check": "oxfmt src/"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "@tanstack/react-query": "5.100.5",
    "@tanstack/react-router": "1.168.24",
    "hono": "4.12.15",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@resvg/resvg-js": "2.6.2",
    "@types/bun": "latest",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "typescript": "6.0.3"
  }
}

{
  "name": "house-inventory",
  "version": "0.2.2",
  "description": "House asset inventory — Home Assistant add-on",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun run scripts/build.ts",
    "build:backend": "bun build ./src/index.ts --target=bun --outdir=./dist --minify",
    "start": "bun dist/index.js",
    "test": "bun test src/__tests__/",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.frontend.json",
    "lint": "oxlint src/frontend/",
    "fmt": "oxfmt --write src/",
    "fmt:check": "oxfmt src/"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.75.5",
    "@tanstack/react-router": "^1.120.3",
    "hono": "^4.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/bun": "latest",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^5.6.0"
  }
}

# Dev-mode config. In the HA add-on, these are injected automatically by /etc/services.d/house-inventory/run.

# Your Home Assistant URL (no trailing slash).
HA_BASE_URL=http://homeassistant.local:8123

# Long-lived access token: HA → profile → Security → "Long-lived access tokens".
HA_TOKEN=

# Where SQLite + manuals live in dev (add-on uses /data).
DATA_DIR=./data

# Port the HTTP server binds to.
PORT=8099

# AI Task entity backed by your OpenRouter conversation agent.
# Find it under Settings → Devices & Services → AI Task.
AI_TASK_ENTITY_ID=ai_task.openrouter

# "duckduckgo" needs no key. "brave" requires BRAVE_SEARCH_API_KEY.
WEB_SEARCH_PROVIDER=duckduckgo
BRAVE_SEARCH_API_KEY=

LOG_LEVEL=info
